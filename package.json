{
  "name": "memorymesh",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Portable local memory for MCP-native coding agents",
  "homepage": "https://github.com/Cognostra/MemoryMesh",
  "repository": {
    "type": "git",
    "url": "https://github.com/Cognostra/MemoryMesh.git"
  },
  "bugs": {
    "url": "https://github.com/Cognostra/MemoryMesh/issues"
  },
  "scripts": {
    "memorymesh": "bun run src/cli.ts",
    "dev": "bun run src/cli.ts",
    "docs:check": "bun run scripts/check-docs.ts",
    "skills:check": "bun run scripts/check-skills.ts",
    "test": "bun test",
    "bench": "bun run bench/run.ts",
    "proof": "bun run scripts/generate-proof.ts",
    "eval:repo": "bun run src/cli.ts eval bench/queries-memorymesh.json .",
    "build:local": "bash ./scripts/build-release.sh local",
    "package:local": "bash ./scripts/package-release.sh ./dist/memorymesh",
    "release-check": "bash ./scripts/release-check.sh"
  }
}
